const CONTACTED_FILE = 'contacted_users.json';

// ⚙️ CONFIGURAÇÕES
const NOME_CHANNEL = 'AZAMAX'; // Nome do seu channel
const ENVIAR_MENSAGEM_INIT = true; // true = envia mensagem ao iniciar, false = não envia

function loadContactedUsers() {
    try {
        if (fs.existsSync(CONTACTED_FILE)) {
            return JSON.parse(fs.readFileSync(CONTACTED_FILE, 'utf8'));
        }
    } catch (error) {
        console.error('Erro ao carregar usuários contatados:', error);
    }
    return [];
}

function saveContactedUsers(users) {
    try {
        fs.writeFileSync(CONTACTED_FILE, JSON.stringify(users, null, 2));
    } catch (error) {
        console.error('Erro ao salvar usuários contatados:', error);
    }
}

// Função para encontrar resposta automática
function encontrarResposta(mensagem) {
    const msg = mensagem.toLowerCase().trim();
    
    // Procurar correspondência exata
    if (RESPOSTAS_AUTOMATICAS[msg]) {
        return RESPOSTAS_AUTOMATICAS[msg];
    }
    
    // Procurar por palavras-chave
    for (const [chave, resposta] of Object.entries(RESPOSTAS_AUTOMATICAS)) {
        if (msg.includes(chave)) {
            return resposta;
        }
    }
    
    return null;
}

// ✅ FUNÇÃO PARA ENVIAR MENSAGEM NO CHANNEL
async function enviarMensagemNoChannel(mensagem) {
    try {
        const chats = await client.getChats();
        console.log(`📊 Total de chats: ${chats.length}`);
        
        for (const chat of chats) {
            console.log(`🔍 Analisando: ${chat.name} (isGroup: ${chat.isGroup})`);
            
            // Procurar pelo channel pelo nome
            if (chat.name && chat.name.toLowerCase().includes(NOME_CHANNEL.toLowerCase())) {
                console.log(`✅ Channel encontrado: ${chat.name}`);
                
                await chat.sendMessage(mensagem);
                console.log(`✅ Mensagem enviada no Channel: ${chat.name}`);
                return true;
            }
        }
        
        console.log(`❌ Channel "${NOME_CHANNEL}" não encontrado!`);
        return false;
        
    } catch (error) {
        console.error('❌ Erro ao enviar mensagem no channel:', error);
        return false;
    }
}

