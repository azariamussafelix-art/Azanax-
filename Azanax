// Message Handler - Responde em Chats normais E WhatsApp Channel
client.on('message', async message => {
    const msg = message.body.toLowerCase().trim();
    const userId = message.from;
    const isChannel = message.isFromMe === false && message.chatId.includes('@broadcast');
    const isBroadcast = message.broadcast;

    try {
        console.log(`📨 Mensagem recebida ${isChannel ? '[CHANNEL]' : '[CHAT]'}: ${msg}`);
        
        // MENU
        if (msg === 'menu') {
            await message.reply(MENU_MESSAGE);
            return;
        }
        
        // OPÇÃO 1 - MÚSICA
        if (msg === '1' || msg.startsWith('musica ')) {
            if (msg === '1') {
                await message.reply(`🎵 Digite a música que deseja:\n\nExemplo: musica despacito`);
            } else {
                const songName = msg.replace('musica ', '').trim();
                
                if (songName.length === 0) {
                    await message.reply(`🎵 Use assim: "musica [nome da música]"`);
                    return;
                }

                const link = `https://www.youtube.com/results?search_query=${encodeURIComponent(songName)}`;
                await message.reply(`🎧 Aqui está sua música:\n${link}`);
                console.log(`🎵 Música procurada: ${songName}`);
            }
            return;
        }
        
        // OPÇÃO 2 - GANHAR DINHEIRO
        if (msg === '2') {
            await message.reply(MONEY_MESSAGE);
            console.log(`💰 Usuário acessou links de ganhar dinheiro`);
            return;
        }
        
        // OPÇÃO 3 - SUPORTE
        if (msg === '3') {
            await message.reply(SUPPORT_MESSAGE);
            console.log(`📞 Usuário solicitou suporte`);
            return;
        }
        
        // Procurar por resposta automática
        const resposta = encontrarResposta(msg);
        if (resposta) {
            await message.reply(resposta);
            console.log(`💬 Resposta automática enviada: ${msg} ${isChannel ? '[CHANNEL]' : '[CHAT]'}`);
            return;
        }
        
        // Se não encontrar resposta, enviar menu padrão
        await message.reply(INVALID_MESSAGE);
        
    } catch (error) {
        console.error('❌ Erro ao processar mensagem:', error);
        try {
            await message.reply('❌ Desculpe, ocorreu um erro. Tente novamente.');
        } catch (replyError) {
            console.error('❌ Erro ao enviar resposta de erro:', replyError);
        }
    }
});

// Evento específico para mensagens de canal
client.on('message_create', async message => {
    try {
        // Verificar se é mensagem de channel/broadcast
        if (message.isFromMe === false && (message.chatId.includes('@broadcast') || message.broadcast)) {
            const msg = message.body.toLowerCase().trim();
            
            console.log(`📢 [CHANNEL MESSAGE] ${msg}`);
            
            // Enviar resposta automática no channel
            const resposta = encontrarResposta(msg);
            if (resposta) {
                await message.reply(resposta);
                console.log(`✅ Resposta enviada no Channel`);
            }
        }
    } catch (error) {
        console.error('❌ Erro ao processar mensagem de channel:', error);
    }
});

